# --- Secrets (NEVER commit) ---
.env
secrets/
*.token.json
credentials.json
token.json
# bonus_partner.local.json — holds the partner's tokens/URLs
*.local.json

# --- Python ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/

# --- Runtime output (logs/artefacts are committed selectively; ignore bulk) ---
logs/*.jsonl
!logs/.gitkeep
!logs/sample-match.jsonl
