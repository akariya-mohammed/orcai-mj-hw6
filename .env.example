# Copy this file to ".env" and fill in what you use. .env is gitignored.
#
#   cp .env.example .env
#
# Default LLM provider is Ollama (local) — needs NO key. Only set a key if you
# switch config.yaml -> llm.provider to "anthropic" or "gemini".

# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Bearer tokens that protect each MCP server URL (required for the cloud level).
# Generate strong random values, e.g.:  python -c "import secrets;print(secrets.token_urlsafe(32))"
COP_MCP_TOKEN=
THIEF_MCP_TOKEN=

# Token for the partner group's MCP servers (cross-group bonus game).
# OPPONENT_MCP_TOKEN=
